# MQ-Sentinel — production environment file. Edit then `systemctl restart mq-sentinel`.

# --- Server ----------------------------------------------------------------
MQS_SERVER_ENVIRONMENT=prod
MQS_SERVER_TRANSPORT=http
MQS_SERVER_HTTP_HOST=127.0.0.1
MQS_SERVER_HTTP_PORT=8080

# --- Audit -----------------------------------------------------------------
MQS_AUDIT_LOG_PATH=/var/log/mq-sentinel/audit.jsonl

# --- OIDC (REQUIRED in prod) -----------------------------------------------
# Refuses to start in prod with these unset.
# MQS_AUTH_OIDC_ISSUER=https://login.example.com/realms/mq-sentinel
# MQS_AUTH_OIDC_AUDIENCE=mq-sentinel
# MQS_AUTH_OIDC_JWKS_URL=https://login.example.com/.well-known/jwks.json

# --- Security knobs --------------------------------------------------------
MQS_SECURITY_RATE_LIMIT_PER_MINUTE=60

# --- IBM MQ client libraries -----------------------------------------------
# pymqi requires libmqic_r — set this if MQ client is in /opt/mqm
LD_LIBRARY_PATH=/opt/mqm/lib64:/opt/mqm/lib

# --- Telemetry (optional) --------------------------------------------------
# MQS_TELEMETRY_OTLP_ENDPOINT=otlp-collector.internal:4317
